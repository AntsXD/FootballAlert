# --- football-data.org ---
# Sign up at https://www.football-data.org/client/register (free) and paste the key here.
FOOTBALL_DATA_API_KEY=your_key_here

# --- WhatsApp target group ---
# Run `npm run list` after linking your account; it prints your groups with their IDs.
# A group ID looks like 120363xxx@g.us. Paste it here.
WHATSAPP_GROUP_ID=

# --- Polling (minutes). 2 minutes is safe under the free 10 req/min limit. ---
POLL_INTERVAL_MIN=2

# --- Only announce matches that FINISHED within the last N hours. ---
# Prevents the bot from dumping old tournament history on a fresh install.
# A WC match lasts ~2h (up to ~2.5h with ET/penalties), so 4h is a safe window.
LOOKBACK_HOURS=4

# --- Optional: filter the upcoming competition. WC = FIFA World Cup. ---
COMPETITION_CODE=WC

# --- Optional: also post live score changes as they happen (true/false). ---
# Off by default. Turning this on roughly doubles API usage — stay under 10 req/min.
ALERT_LIVE=false

# --- Optional: one-time greeting posted to the group when the bot boots. ---
# Use \n for line breaks. Set to empty or false to disable.
BOOT_GREETING=👋 FootballAlert is live! I'll post World Cup results here as they finish.
# Only send the boot greeting once per calendar day (so restarts don't spam).
BOOT_GREETING_DAILY=true
# Append the next upcoming fixture to the boot greeting.
BOOT_GREETING_FIXTURE=true
